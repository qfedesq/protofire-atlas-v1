{
  "name": "protofire-atlas-v1",
  "version": "1.29.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "data:sync": "node scripts/sync-atlas-data.mjs",
    "data:sync-external": "node --import tsx scripts/sync-external-chain-metrics.ts",
    "data:refresh-top30": "bash scripts/refresh-top-30-evm-chains.sh",
    "reports:generate": "node --import tsx scripts/generate-reports.ts",
    "version:bump": "node scripts/bump-version.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:data": "vitest run tests/data",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run validate:data && npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "^4.16.0",
    "@types/pg": "^8.18.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "openai": "^6.27.0",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
